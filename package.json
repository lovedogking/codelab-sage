{
  "name": "codelab-sage",
  "version": "0.1.0",
  "description": "A terminal CLI agent distilled from the wisdom of Codelab.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "sage": "bin/sage.js",
    "codelab-sage": "bin/sage.js"
  },
  "files": [
    "dist",
    "bin",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli/index.ts",
    "start": "node bin/sage.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"bin/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\" \"bin/**/*.js\"",
    "prepare": "npm run build"
  },
  "keywords": [
    "cli",
    "agent",
    "llm",
    "codelab",
    "ai",
    "tool-calling"
  ],
  "author": "Codelab",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "fs-extra": "^11.2.0",
    "openai": "^4.63.0",
    "ora": "^8.1.0",
    "yaml": "^2.5.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.16.5",
    "@typescript-eslint/eslint-plugin": "^8.6.0",
    "@typescript-eslint/parser": "^8.6.0",
    "eslint": "^8.57.1",
    "prettier": "^3.3.3",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
